diff --git a/hopper/topk_warpselect_probe.h b/hopper/topk_warpselect_probe.h
new file mode 100644
index 0000000..372ce96
--- /dev/null
+++ b/hopper/topk_warpselect_probe.h
@@ -0,0 +1,298 @@
+/******************************************************************************
+ * community_kv: per-thread WarpSelect-style top-K probe with cross-quad merge.
+ *
+ *   Phase 5e (A) Half 1 — kernel-internal only.
+ *
+ *   Per-thread state:
+ *     - topk_v[r][K], topk_i[r][K]  : sorted DESCENDING (topk_v[r][K-1] = tau)
+ *     - buf_v[r][B],  buf_i[r][B]   : unsorted overflow
+ *     - buf_count[r]
+ *
+ *   update(scores, coord_rc, n_block_offset):
+ *     for each col: if score > tau, push (score, n_block_offset + coord_col)
+ *                   if buf full, merge_row and reset
+ *
+ *   merge_row(r):
+ *     pad (topk_v + buf_v) up to NextPow2 with -INF
+ *     bitonic-sort DESC, take first K
+ *
+ *   finalize_and_normalize(softmax_scale_log2, row_max, lse_natural):
+ *     1. drain buffer for each row
+ *     2. cross-quad butterfly merge (delta=1, delta=2) so each row-mate thread
+ *        ends up with the same union top-K of the row's 4 row-mate threads
+ *     3. (Half 1) keep_alive via inline asm so ptxas doesn't DCE everything
+ *
+ *   This is "Variant A": cross-quad merge during finalize. Cross-quad merge in
+ *   the streaming update path is left for a follow-up if measurements warrant.
+ *
+ * NO memory write yet (Half 1). NO inter-warp sync. K is a template parameter
+ * (callers in CommunityKV dispatch over {2, 4, 8, 16, 32}); B=16 fixed.
+ ******************************************************************************/
+
+#pragma once
+
+#include <cute/tensor.hpp>
+#include <cutlass/numeric_types.h>
+
+namespace flash {
+
+using namespace cute;
+
+// Bitonic sort DESCENDING: a[0] = max, a[N-1] = min.
+template <int N>
+CUTLASS_DEVICE void bitonic_sort_desc_kv(float* v, int* idx) {
+    static_assert((N & (N - 1)) == 0, "N must be power of 2");
+    #pragma unroll
+    for (int k = 2; k <= N; k *= 2) {
+        #pragma unroll
+        for (int j = k / 2; j > 0; j /= 2) {
+            #pragma unroll
+            for (int i = 0; i < N; ++i) {
+                int ix = i ^ j;
+                if (ix > i) {
+                    bool descending = ((i & k) == 0);
+                    bool need_swap = descending ? (v[i] < v[ix]) : (v[i] > v[ix]);
+                    if (need_swap) {
+                        float tv = v[i]; v[i] = v[ix]; v[ix] = tv;
+                        int   ti = idx[i]; idx[i] = idx[ix]; idx[ix] = ti;
+                    }
+                }
+            }
+        }
+    }
+}
+
+// 2-way merge of two DESC-sorted lists of length K, keep top-K.
+// `a_v`, `a_i` are the local thread's list (and the destination).
+// `b_v`, `b_i` are the other thread's list (received via shfl_xor).
+template <int K>
+CUTLASS_DEVICE void merge_two_desc_keep_top_k(
+        float* a_v, int* a_i,
+        float const* b_v, int const* b_i)
+{
+    float out_v[K]; int out_i[K];
+    int ai = 0, bi = 0;
+    #pragma unroll
+    for (int k = 0; k < K; ++k) {
+        // pick the larger head; on tie, prefer a's
+        bool take_a = (ai < K) && (bi >= K || a_v[ai] >= b_v[bi]);
+        out_v[k] = take_a ? a_v[ai] : b_v[bi];
+        out_i[k] = take_a ? a_i[ai] : b_i[bi];
+        ai += take_a ? 1 : 0;
+        bi += take_a ? 0 : 1;
+    }
+    #pragma unroll
+    for (int k = 0; k < K; ++k) { a_v[k] = out_v[k]; a_i[k] = out_i[k]; }
+}
+
+template <int kNRows, int K, int B>
+struct WarpSelectProbe {
+    static_assert((K & (K - 1)) == 0, "K must be power of 2");
+    static_assert((B & (B - 1)) == 0, "B must be power of 2");
+    static constexpr int Combined = K + B;
+    static constexpr int NextPow2 =
+        (Combined <= 16)  ? 16  :
+        (Combined <= 32)  ? 32  :
+        (Combined <= 64)  ? 64  :
+        (Combined <= 128) ? 128 : 256;
+
+    float topk_v[kNRows][K];   // DESC, topk_v[r][K-1] = tau
+    int   topk_i[kNRows][K];
+    float buf_v [kNRows][B];
+    int   buf_i [kNRows][B];
+    int   buf_count[kNRows];
+
+    CUTLASS_DEVICE WarpSelectProbe() {
+        #pragma unroll
+        for (int r = 0; r < kNRows; ++r) {
+            buf_count[r] = 0;
+            #pragma unroll
+            for (int k = 0; k < K; ++k) { topk_v[r][k] = -INFINITY; topk_i[r][k] = -1; }
+            #pragma unroll
+            for (int b = 0; b < B; ++b) { buf_v [r][b] = -INFINITY; buf_i [r][b] = -1; }
+        }
+    }
+
+    // Combine topk(K) + buf(count) into NextPow2 padded with -INF, bitonic-sort DESC,
+    // keep first K (largest). buf contents are discarded (count reset by caller).
+    // `count` is the number of VALID entries in buf_v[r][0..count); entries past count
+    // may be stale from a previous fill (we reset only the count, not the values).
+    CUTLASS_DEVICE void merge_row(int r, int count) {
+        float c_v[NextPow2]; int c_i[NextPow2];
+        #pragma unroll
+        for (int k = 0; k < K; ++k) { c_v[k] = topk_v[r][k]; c_i[k] = topk_i[r][k]; }
+        #pragma unroll
+        for (int b = 0; b < B; ++b) {
+            bool valid = b < count;
+            c_v[K + b] = valid ? buf_v[r][b] : -INFINITY;
+            c_i[K + b] = valid ? buf_i[r][b] : -1;
+        }
+        #pragma unroll
+        for (int i = Combined; i < NextPow2; ++i) { c_v[i] = -INFINITY; c_i[i] = -1; }
+        bitonic_sort_desc_kv<NextPow2>(c_v, c_i);
+        #pragma unroll
+        for (int k = 0; k < K; ++k) { topk_v[r][k] = c_v[k]; topk_i[r][k] = c_i[k]; }
+    }
+
+    // scores: rowcol-converted accumulator fragment, shape (kNRows, ncol).
+    // coord:  same shape, holds (row,col) pairs from a partitioned identity tensor.
+    // n_block_offset: absolute kv col index of column 0 in this n-block.
+    // kv_start: exclude kv cols [0, kv_start) from candidates (sink tokens).
+    template <typename ScoresT, typename CoordT>
+    CUTLASS_DEVICE void update(ScoresT const& scores, CoordT const& coord, int n_block_offset, int kv_start) {
+        constexpr int ncol = decltype(size<1>(scores))::value;
+        #pragma unroll
+        for (int r = 0; r < kNRows; ++r) {
+            float tau   = topk_v[r][K - 1];
+            int   count = buf_count[r];
+            #pragma unroll
+            for (int c = 0; c < ncol; ++c) {
+                float val = scores(r, c);
+                int abs_col = n_block_offset + get<1>(coord(r, c));
+                if (val > tau && abs_col >= kv_start) {
+                    buf_v[r][count] = val;
+                    buf_i[r][count] = abs_col;
+                    ++count;
+                    if (count == B) {
+                        merge_row(r, B);
+                        count = 0;
+                        tau   = topk_v[r][K - 1];
+                    }
+                }
+            }
+            buf_count[r] = count;
+        }
+    }
+
+    // Drain buffer + cross-quad butterfly merge.
+    // After this returns, all 4 row-mate lanes hold the same top-K of the row's
+    // union state. softmax_scale_log2 + lse_natural normalize values to softmax
+    // probabilities (kept inline, not yet written to gmem in Half 1).
+    //
+    // row_max / lse_natural are held by the Softmax struct after Softmax::finalize.
+    template <typename TensorMax, typename TensorLse>
+    CUTLASS_DEVICE void finalize_and_normalize(
+            float softmax_scale_log2,
+            TensorMax const& row_max,
+            TensorLse  const& lse_natural)
+    {
+        (void)row_max;  // currently unused; reserved for future per-row sanity asserts
+
+        #pragma unroll
+        for (int r = 0; r < kNRows; ++r) {
+            // 1. Drain remaining buffer entries
+            if (buf_count[r] > 0) {
+                merge_row(r, buf_count[r]);
+                buf_count[r] = 0;
+            }
+
+            // 2. Cross-quad butterfly merge: delta=1 then delta=2.
+            //    After both, every row-mate lane holds the union top-K.
+            #pragma unroll
+            for (int delta = 1; delta <= 2; delta <<= 1) {
+                float other_v[K]; int other_i[K];
+                #pragma unroll
+                for (int k = 0; k < K; ++k) {
+                    other_v[k] = __shfl_xor_sync(0xffffffff, topk_v[r][k], delta);
+                    other_i[k] = __shfl_xor_sync(0xffffffff, topk_i[r][k], delta);
+                }
+                merge_two_desc_keep_top_k<K>(topk_v[r], topk_i[r], other_v, other_i);
+            }
+
+            // 3. Normalize values to softmax probabilities.
+            //    P(s) = exp2(s * scale_log2 - LSE * log2(e))
+            //    where LSE_natural = log(Z_natural) and the exp2 form matches FA3's exp path.
+            float const lse_log2 = lse_natural(r) * float(M_LOG2E);
+            #pragma unroll
+            for (int k = 0; k < K; ++k) {
+                topk_v[r][k] = exp2f(topk_v[r][k] * softmax_scale_log2 - lse_log2);
+            }
+        }
+    }
+
+    // Force ptxas to keep the running topk live in Half 1 (no gmem write yet).
+    CUTLASS_DEVICE void keep_alive() {
+        #pragma unroll
+        for (int r = 0; r < kNRows; ++r) {
+            #pragma unroll
+            for (int k = 0; k < K; ++k) {
+                asm volatile("" :: "f"(topk_v[r][k]));
+                asm volatile("" :: "r"(topk_i[r][k]));
+            }
+        }
+    }
+
+    // Half 2: write top-K (val, idx) to gmem.
+    //   coord_rc          : per-thread (row,col) coords of the QK accumulator fragment
+    //                       (same one fed to update()), used to elect ONE thread per row to
+    //                       write and to recover the in-block row index.
+    //   m_block_row_offset: m_block * kBlockM (caller pre-folds; probe doesn't know kBlockM).
+    //   bidh              : head-id (kv-head when PackGQA) from block_coord
+    //   bidb              : batch-id from block_coord
+    //   qhead_per_khead   : 1 when !PackGQA; otherwise H / H_kv
+    //   seqlen_q          : query seqlen for OOB check
+    //   q_skip            : skip the first q_skip q-rows; output is allocated as
+    //                       [B, H, seqlen_q - q_skip, K] and we write to row (q_idx - q_skip).
+    //   ptr_val/ptr_idx   : base ptrs to topk_val [B,H,Sq-q_skip,K] fp32 / topk_idx int32.
+    //                       If either is nullptr, write is skipped (cheap runtime gate).
+    //   stride_b/h/row    : strides in elements for batch/head/row dims (last dim is contiguous).
+    template <typename CoordT>
+    CUTLASS_DEVICE void write_to_gmem(
+            CoordT const& coord_rc,
+            int m_block_row_offset,
+            int bidh,
+            int bidb,
+            int qhead_per_khead,
+            int seqlen_q,
+            int q_skip,
+            float*  ptr_val,
+            int32_t* ptr_idx,
+            int64_t stride_batch,
+            int64_t stride_head,
+            int64_t stride_row)
+    {
+        if (ptr_val == nullptr || ptr_idx == nullptr) return;
+        #pragma unroll
+        for (int r = 0; r < kNRows; ++r) {
+            // Elect one thread per row: the row-mate lane whose col coord is 0.
+            // After cross-quad butterfly merge in finalize_and_normalize(), all 4 row-mate
+            // lanes hold the same union top-K, so any one writer suffices.
+            if (get<1>(coord_rc(r, _0{})) != 0) continue;
+
+            int const row_in_block = get<0>(coord_rc(r, _0{}));
+            int const abs_row = m_block_row_offset + row_in_block;
+            int const h_inner = (qhead_per_khead == 1) ? 0 : (abs_row % qhead_per_khead);
+            int const q_idx   = (qhead_per_khead == 1) ? abs_row : (abs_row / qhead_per_khead);
+            int const abs_h   = bidh * qhead_per_khead + h_inner;
+            if (q_idx >= seqlen_q || q_idx < q_skip) continue;
+            int const out_row = q_idx - q_skip;
+
+            int64_t const base = int64_t(bidb) * stride_batch
+                               + int64_t(abs_h) * stride_head
+                               + int64_t(out_row) * stride_row;
+            float*   row_val  = ptr_val + base;
+            int32_t* row_idxp = ptr_idx + base;
+            #pragma unroll
+            for (int k = 0; k < K; ++k) {
+                row_val[k]  = topk_v[r][k];
+                row_idxp[k] = topk_i[r][k];
+            }
+        }
+    }
+};
+
+// Empty stub used in template instantiations where we don't want the probe.
+struct WarpSelectProbeNoOp {
+    CUTLASS_DEVICE WarpSelectProbeNoOp() {}
+    template <typename ScoresT, typename CoordT>
+    CUTLASS_DEVICE void update(ScoresT const&, CoordT const&, int, int) {}
+    template <typename TensorMax, typename TensorLse>
+    CUTLASS_DEVICE void finalize_and_normalize(float, TensorMax const&, TensorLse const&) {}
+    CUTLASS_DEVICE void keep_alive() {}
+    template <typename CoordT>
+    CUTLASS_DEVICE void write_to_gmem(
+            CoordT const&, int, int, int, int, int, int,
+            float*, int32_t*, int64_t, int64_t, int64_t) {}
+};
+
+}  // namespace flash
