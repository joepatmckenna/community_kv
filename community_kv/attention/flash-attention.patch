+// community_kv top-K: dispatch params.topk_K (runtime) to a compile-time
+// constant TOPK_NAME. Limited to {2, 4, 8, 16, 32} — the supported probe widths.
+// Default to 8 outside this set so non-probe paths remain valid; flash_api
+// validates topk_K independently when return_topk=true.
+#define TOPK_SWITCH(TOPK_VAL, TOPK_NAME, ...)                                                    \
+  [&] {                                                                                          \
+    if (TOPK_VAL == 2) {                                                                         \
+      constexpr static int TOPK_NAME = 2;                                                        \
+      return __VA_ARGS__();                                                                      \
+    } else if (TOPK_VAL == 4) {                                                                  \
+      constexpr static int TOPK_NAME = 4;                                                        \
+      return __VA_ARGS__();                                                                      \
